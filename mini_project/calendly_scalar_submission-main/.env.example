# Backend Configuration
# Use Spring Boot backend (port 8081) or Node.js backend (port 3000)
VITE_API_URL=http://localhost:8081

# GEMINI_API_KEY: Required for Gemini AI API calls.
# automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
